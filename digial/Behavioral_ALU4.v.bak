module Behavioral_ALU4 (input [3:0] a, b,input [2:0] op,output reg [3:0] result , output reg Cout);

wire [3:0] bandwire,borwire, addwire,subwire; 
band g1 (a,b,bandwire);
bor g2 (a,b,borwire); 
sub g3 (a,b,op [0], subCout, subwire); 
add g4 (a,b,op[0],addCout,addwire);

always @(*) begin
    // Operation selection based on op
    case (op)
        3'b000: {Cout,result} = {subCout,subwire};   // Subtraction
        3'b001: {Cout,result} = {addCout,addwire};  // Addition
        3'b010: {Cout,result} = bandwire;  // Bitwise OR
        3'b011: {Cout,result} = borwire;  // Bitwise AND
        default: {Cout,result} = {1'bz,4'bz};  // Undefined output
    endcase
end
endmodule
